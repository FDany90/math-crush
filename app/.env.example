# Credenciales de Supabase para las métricas de playtest.
# Copiá este archivo como ".env" (o ".env.local") y completá los valores.
# Los tomás de Supabase → Project Settings → API.
# La "anon key" es pública (segura para el cliente); NO uses la service_role acá.
#
# En Vercel: cargá estas mismas variables en Project → Settings → Environment Variables.
#
# Si estas variables NO están definidas, el juego funciona igual pero guarda
# las métricas solo en localStorage (no las manda a Supabase).

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU-ANON-KEY
